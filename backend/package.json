{
  "name": "cafebombom",
  "version": "1.0.0",
  "bin": "dist/index.js",
  "main": "dist/index.js",
  "description": "POS system for Cafe Bom Bom",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "NODE_ENV=development bun --watch src/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "build:windows": "bun build ./src/index.ts --compile --target=bun-windows-x64 --outfile=pos-app.exe",
    "build:linux": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile=pos-app-linux",
    "build:exe": "bun run build:windows && bun run build:linux"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "pkg": {
    "assets": [
      "dist/**/*",
      "node_modules/drizzle-orm/**/*",
      "node_modules/better-sqlite3/**/*"
    ]
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "latest",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  }
}